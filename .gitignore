# APIキーを含む設定ファイル（ローカル上書き用）
# config.js はAPIキー無しの状態でコミット済み
# ローカルで上書きする場合は git update-index --skip-worktree config.js を実行

# ローカル環境変数（REINFOLIB APIキーを含む）
.env

# proxy.js は REINFOLIB API キーを含むためローカル専用
proxy.js


# GeoJSONデータ（サイズが大きい場合や社外秘データ）
# 必要に応じてコメントアウトを解除
# *.geojson

# macOS システムファイル
.DS_Store

# Claude Code の作業ファイル
.claude/

# Node.js
node_modules/
npm-debug.log*

# エディタ設定
.vscode/
.idea/
